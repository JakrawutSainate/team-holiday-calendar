datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator db {
  provider = "go run github.com/steebchen/prisma-client-go"
}

model TeamMember {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  role          String   // ADMIN, MEMBER, LEAD
  passwordHash  String   @default("")
  avatarUrl     String?
  department    String   // Engineering, Design, Management
  title         String
  tokensBalance Float    @default(0.0)
}

model CalendarEvent {
  id       String  @id @default(uuid())
  userId   String
  userName String
  date     String  // YYYY-MM-DD
  status   String  // NORMAL, WEEKEND_WORK, COMPENSATORY_OFF, PUBLIC_HOLIDAY, HOLIDAY_WORK
  details  String?

  @@index([userId])
  @@index([date])
  @@index([status])
}

model TokenTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // EARN | SPEND
  amount      Float
  description String
  relatedDate String?  // YYYY-MM-DD of the related shift/leave
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model CapacitySetting {
  id            String  @id @default(uuid())
  date          String? // YYYY-MM-DD
  dayOfWeek     Int?    // 0 = Sun, 1 = Mon, ...
  maxOffAllowed Int
  description   String?
}
