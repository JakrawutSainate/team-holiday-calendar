datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


generator db {
  provider = "go run github.com/steebchen/prisma-client-go"
}

model TeamMember {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  role               String   // ADMIN, MEMBER, LEAD
  passwordHash       String   @default("")
  avatarUrl          String?
  department         String   // Engineering, Design, Management
  title              String
  tokensBalance      Float    @default(0.0)
  savedSignature     String?  // Base64 image data
  sickLeaveBalance   Int      @default(30)
  annualLeaveBalance Int      @default(6)
}

model CalendarEvent {
  id           String        @id @default(uuid())
  userId       String
  userName     String
  date         String  // YYYY-MM-DD
  status       String  // NORMAL, WEEKEND_WORK, COMPENSATORY_OFF, PUBLIC_HOLIDAY, HOLIDAY_WORK
  details      String?
  leaveRequest LeaveRequest?

  @@index([userId])
  @@index([date])
  @@index([status])
}

model LeaveRequest {
  id              String        @id @default(uuid())
  eventId         String        @unique
  reason          String?
  signatureType   String        // "DRAW" | "TEXT"
  signatureText   String?
  signatureImage  String?       // Base64 String
  attachmentImage String?       // Base64 String
  event           CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model TokenTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // EARN | SPEND
  amount      Float
  description String
  relatedDate String?  // YYYY-MM-DD of the related shift/leave
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model CapacitySetting {
  id            String  @id @default(uuid())
  date          String? // YYYY-MM-DD
  dayOfWeek     Int?    // 0 = Sun, 1 = Mon, ...
  maxOffAllowed Int
  description   String?
}

model LeaveDocument {
  id           String   @id @default(uuid())
  userId       String
  userName     String
  department   String
  title        String
  leaveDate    String   // YYYY-MM-DD
  leaveType    String   // SICK, CASUAL, ANNUAL, COMPENSATORY
  reason       String
  signature    String   // Base64 image data
  status       String   // PENDING, APPROVED, REJECTED
  attachment   String?  // Base64 encoded image
  rejectReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([leaveDate])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  action    String
  details   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

